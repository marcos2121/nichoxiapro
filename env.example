# ============================================================
#  MarketQuest Insights — Variables de entorno
#  Copia este archivo como .env y rellena con tus valores
# ============================================================

# -----------------------------------------------------------
# SUPABASE
# Encuentra estos valores en: Supabase → Settings → API
# -----------------------------------------------------------

# URL de tu proyecto Supabase
SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co

# Anon key (pública, sin privilegios de admin)
SUPABASE_PUBLISHABLE_KEY=tu_anon_key_aqui
VITE_SUPABASE_PUBLISHABLE_KEY=tu_anon_key_aqui

# ID del proyecto (aparece en la URL de Supabase)
VITE_SUPABASE_PROJECT_ID=tu_project_id_aqui

# -----------------------------------------------------------
# NOTA IMPORTANTE
# Las API keys de los proveedores de IA (Gemini, OpenAI,
# Claude, etc.) NO van aquí. Cada usuario las configura
# directamente desde la interfaz de la app. Se guardan
# encriptadas en tu base de datos Supabase.
# -----------------------------------------------------------
